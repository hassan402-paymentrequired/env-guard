{
    "name": "laramicstudio/env-guard",
    "description": "It lets you define a schema for your .env file — think of it like a contract. When your app boots, it checks your actual .env against that contract and fails loudly and early if something is wrong.It lets you define a schema for your .env file — think of it like a contract. When your app boots, it checks your actual .env against that contract and fails loudly and early if something is wrong.",
    "keywords": [
        "laramic studio",
        "laravel",
        "env-guard"
    ],
    "homepage": "https://github.com/laramicstudio/env-guard",
    "license": "MIT",
    "authors": [
        {
            "name": "hassan lateef",
            "email": "lateefoluwafemi303@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "LaramicStudio\\EnvGuard\\": "src/",
            "LaramicStudio\\EnvGuard\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaramicStudio\\EnvGuard\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaramicStudio\\EnvGuard\\EnvGuardServiceProvider"
            ],
            "aliases": {
                "EnvGuard": "LaramicStudio\\EnvGuard\\Facades\\EnvGuard"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
